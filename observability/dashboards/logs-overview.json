      "pluginVersion": "11.2.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "{compose_service=~\".+\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Container Logs",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.2.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (compose_service) (count_over_time({compose_service=~\".+\"}[$__interval]))",
          "legendFormat": "{{compose_service}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Logs by Service",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "11.2.0",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (detected_level) (count_over_time({detected_level=~\".+\"}[$__interval]))",
          "legendFormat": "{{detected_level}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Logs by Level",
      "type": "piechart"
